<Window x:Class="POEPart3.FilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POEPart3"
        mc:Ignorable="d"
        Title="Filter Recipes" Height="300" Width="400">
    <Grid>
        <StackPanel>
            <TextBlock Text="Filter Recipes" FontSize="16" HorizontalAlignment="Center"/>
            <TextBlock Text="Enter ingredient name:"/>
            <TextBox Name="IngredientTextBox" Width="200"/>
            <TextBlock Text="Enter food group:"/>
            <TextBox Name="FoodGroupTextBox" Width="200"/>
            <TextBlock Text="Enter max calories:"/>
            <TextBox Name="MaxCaloriesTextBox" Width="200"/>
            <Button Content="Apply Filter" Click="ApplyFilter_Click"/>
            <Button Content="Close" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>