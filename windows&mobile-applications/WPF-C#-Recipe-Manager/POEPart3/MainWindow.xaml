<Window x:Class="POEPart3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POEPart3"
        mc:Ignorable="d"
        Title="Recipe Application" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="309*"/>
            <ColumnDefinition Width="91*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.ColumnSpan="2" Background="#FF2F4D5A">
            <TextBlock Text="Welcome to the Recipe Application!" FontSize="20" HorizontalAlignment="Center"/>
            <Button Content="Enter new recipes" Click="EnterRecipes_Click" Margin="5"/>
            <Button Content="Display all recipes" Click="DisplayRecipes_Click" Margin="5"/>
            <Button Content="Select and display a recipe" Click="SelectRecipe_Click" Margin="5"/>
            <Button Content="Reset current recipe quantities" Click="ResetQuantities_Click" Margin="5"/>
            <Button Content="Scale current recipe" Click="ScaleRecipe_Click" Margin="5"/>
            <Button Content="Set high-calorie notification" Click="SetHighCalorieNotification_Click" Margin="5"/>
            <Button Content="Filter recipes" Click="FilterRecipes_Click" Margin="5"/>
            <Button Content="Exit" Click="Exit_Click" Margin="5"/>
            <ListView Name="RecipeListView" Margin="10">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Recipe Name" DisplayMemberBinding="{Binding Name}" Width="200"/>
                        <GridViewColumn Header="Ingredients" DisplayMemberBinding="{Binding IngredientsDisplay}" Width="300"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>
    </Grid>
</Window>