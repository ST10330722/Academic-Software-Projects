<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.harvestlinkapp">


    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application

        android:allowBackup="true"
        android:icon="@mipmap/hl_icon"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/hl_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.HarvestLinkApp"
        android:usesCleartextTraffic="true">

        <service
            android:name=".push.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>


        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>


        <activity
            android:name=".ui.theme.auth.LoginActivity"
            android:exported="false" />


        <activity
            android:name=".ui.theme.role.RoleSelectActivity"
            android:exported="false" />


        <activity
            android:name=".ui.theme.farmer.FarmerHomeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.theme.farmer.AddEditProduceActivity"
            android:exported="false" />
        <activity
            android:name=".ui.theme.farmer.FarmerOrdersActivity"
            android:exported="false" />


        <activity
            android:name=".ui.theme.buyer.BuyerHomeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.theme.buyer.BuyerOrdersActivity"
            android:exported="false" />


        <activity
            android:name=".ui.theme.settings.SettingsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.theme.buyer.BuyerProduceDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.theme.farmer.FarmerPastOrdersActivity"
            android:exported="false" />

        <activity
            android:name=".ui.theme.buyer.BuyerPastOrdersActivity"
            android:exported="false" />
    </application>

</manifest>
