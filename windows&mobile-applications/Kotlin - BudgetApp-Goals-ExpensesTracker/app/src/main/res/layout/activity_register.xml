<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/material_dynamic_neutral60"
    tools:context=".register">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/material_dynamic_neutral60"
        android:paddingBottom="24dp"
        android:text="Create an Account"
        android:textColor="@android:color/black"
        android:textSize="24sp"
        tools:layout_editor_absoluteX="107dp"
        tools:layout_editor_absoluteY="99dp" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter Your Full Name, Email, And Password To Create An Account"
        android:textSize="12sp"
        tools:layout_editor_absoluteX="26dp"
        tools:layout_editor_absoluteY="173dp" />

    <EditText
        android:id="@+id/emailInput"
        android:layout_width="249dp"
        android:layout_height="50dp"
        android:hint="Email"
        android:inputType="textEmailAddress"
        tools:layout_editor_absoluteX="81dp"
        tools:layout_editor_absoluteY="355dp" />

    <EditText
        android:id="@+id/passwordInput"
        android:layout_width="249dp"
        android:layout_height="wrap_content"
        android:hint="Password"
        android:inputType="textPassword"
        tools:layout_editor_absoluteX="81dp"
        tools:layout_editor_absoluteY="439dp" />

    <Button
        android:id="@+id/registerButton"
        android:layout_width="265dp"
        android:layout_height="50dp"
        android:backgroundTint="@color/material_dynamic_neutral10"
        android:text="Register"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        tools:layout_editor_absoluteX="75dp"
        tools:layout_editor_absoluteY="546dp" />

    <TextView
        android:id="@+id/loginRedirectText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:text="Already have an account? Log In"
        android:textColor="@color/material_dynamic_neutral_variant0"
        tools:layout_editor_absoluteX="103dp"
        tools:layout_editor_absoluteY="641dp" />

    <EditText
        android:id="@+id/nameInput"
        android:layout_width="249dp"
        android:layout_height="wrap_content"
        android:hint="Full Name"
        android:inputType="textPersonName"
        tools:layout_editor_absoluteX="81dp"
        tools:layout_editor_absoluteY="278dp" />

</androidx.constraintlayout.widget.ConstraintLayout>