<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/material_dynamic_neutral60"
    android:paddingTop="?attr/actionBarSize"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Welcome!"
            android:textColor="@color/black"
            android:textSize="24sp" />

        <Button
            android:id="@+id/createCategoryButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/material_dynamic_neutral10"
            android:text="Create Category"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btnAddExpense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/material_dynamic_neutral10"
            android:text="Add Expense Entry"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btnSetBudgetGoals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/material_dynamic_neutral10"
            android:text="Set Monthly Budget Goals"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btnViewExpenses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/material_dynamic_neutral10"
            android:text="View Expenses"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/btnViewCategoryTotals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"
            android:backgroundTint="@color/material_dynamic_neutral10"
            android:text="View Category Totals"
            android:textColor="@color/white" />
        <Button
            android:id="@+id/btnRecurringExpenses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage Recurring Expenses"
            android:layout_marginTop="8dp"/>
        <Button
            android:id="@+id/btnLearningHub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Financial Tips and Learning Hub"
            android:layout_marginTop="8dp"/>
        <Button
            android:id="@+id/btnGoalSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monthly Goal Summary"
            android:layout_marginTop="12dp"/>

    </LinearLayout>
</ScrollView>
