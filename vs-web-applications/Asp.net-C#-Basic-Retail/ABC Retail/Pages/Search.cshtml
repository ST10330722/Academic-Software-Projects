@page
@model ABC_Retail.Pages.SearchModel
@{
    ViewData["Title"] = "Search Data in Cloud";
}

<h2>Search Information in Cloud</h2>

<!-- Search Form -->
<form method="post" asp-page-handler="Search">
    <div class="form-group">
        <label for="searchType">Search Type:</label>
        <select id="searchType" name="searchType" class="form-control" required>
            <option value="profile">Customer Profile</option>
            <option value="image">Image</option>
            <option value="order">Order</option>
            <option value="contract">Contract/Logs</option>
        </select>
    </div>

    <div class="form-group">
        <label for="searchTerm">Search Term:</label>
        <input type="text" id="searchTerm" name="searchTerm" class="form-control" placeholder="Enter search term" required />
    </div>

    <button type="submit" class="btn btn-primary">Search</button>
</form>

<!-- Display Profile Search Results -->
@if (Model.ProfileResults.Any())
{
    <h3>Profile Search Results</h3>
    <table class="table">
        <thead>
            <tr>
                <th>Customer Name</th>
                <th>Product Name</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var profile in Model.ProfileResults)
            {
                <tr>
                    <td>@profile.RowKey</td>
                    <td>@profile["ProductName"]</td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Display Image Search Results -->
@if (Model.ImageResults.Any())
{
    <h3>Image Search Results</h3>
    <ul>
        @foreach (var imageName in Model.ImageResults)
        {
            <li>@imageName</li>
        }
    </ul>
}

<!-- Display Order Search Results -->
@if (Model.OrderResults.Any())
{
    <h3>Order Search Results</h3>
    <ul>
        @foreach (var orderDetail in Model.OrderResults)
        {
            <li>@orderDetail</li>
        }
    </ul>
}

<!-- Display Contract/Log Search Results -->
@if (Model.ContractResults.Any())
{
    <h3>Contract/Log Search Results</h3>
    <ul>
        @foreach (var contractName in Model.ContractResults)
        {
            <li>@contractName</li>
        }
    </ul>
}