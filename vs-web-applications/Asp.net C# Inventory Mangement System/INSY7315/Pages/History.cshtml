@page "{id:int}"
@model INSY7315.Pages.HistoryModel
@{
    // Sets the page title for the browser
    ViewData["Title"] = "Price History";
}

<h2>Price History - @Model.Product.Name</h2>

@* Displays a table showing all price changes for the selected product *@
<table class="table table-striped">
    <thead>
        <tr>
            <th>Changed On</th>
            <th>Old</th>
            <th>New</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var h in Model.History)
        {
            <tr>
                <td>@h.ChangedOn</td>
                <td>@h.OldPrice</td>
                <td>@h.NewPrice</td>
            </tr>
        }
    </tbody>
</table>

@* Button to return to the product details page *@
<p><a class="btn btn-secondary" asp-page="/Details" asp-route-id="@Model.Product.Id">Back</a></p>
