@page
@model INSY7315.Pages.IndexModel
@{
    // Sets the page title
    ViewData["Title"] = "Products";

    // Format the date filters for the form
    var createdFromStr = Model.CreatedFrom?.ToString("yyyy-MM-dd") ?? "";
    var createdToStr = Model.CreatedTo?.ToString("yyyy-MM-dd") ?? "";

    // Helper method to build links that keep filters and change sorting
    string LinkWith(string sortBy, string sortDir, int? pageOverride = null)
        => Url.Page("/Index", new
        {
            Q = Model.Q,
            Category = Model.Category,
            Model = Model.Model,
            MinPrice = Model.MinPrice,
            MaxPrice = Model.MaxPrice,
            CreatedFrom = createdFromStr,
            CreatedTo = createdToStr,
            SortBy = sortBy,
            SortDir = sortDir,
            PageNumber = pageOverride ?? Model.PageNumber
        }) ?? "#";

    // Helper method to keep filters when moving between pages
    string KeepFiltersLink(int page)
        => Url.Page("/Index", new
        {
            Q = Model.Q,
            Category = Model.Category,
            Model = Model.Model,
            MinPrice = Model.MinPrice,
            MaxPrice = Model.MaxPrice,
            CreatedFrom = createdFromStr,
            CreatedTo = createdToStr,
            SortBy = Model.SortBy,
            SortDir = Model.SortDir,
            PageNumber = page
        }) ?? "#";
}

@* Header section with title and export buttons *@
<div class="d-flex align-items-center mb-3">
    <h2 class="mb-0">Products</h2>
    <div class="ms-auto d-flex gap-2">
        <a class="btn btn-sm btn-outline-secondary" href="/api/products/export.csv">Export CSV</a>
        <a class="btn btn-sm btn-outline-secondary" href="/api/products/export.pdf">Export PDF</a>
    </div>
</div>

@* Search and filter form *@
<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <input class="form-control" name="Q" value="@Model.Q" placeholder="Search text..." />
    </div>
    <div class="col-md-2">
        <input class="form-control" name="Category" value="@Model.Category" placeholder="Category" />
    </div>
    <div class="col-md-2">
        <input class="form-control" name="Model" value="@Model.Model" placeholder="Model" />
    </div>
    <div class="col-md-2">
        <input class="form-control" type="number" step="0.01" name="MinPrice" value="@(Model.MinPrice?.ToString())" placeholder="Min price" />
    </div>
    <div class="col-md-2">
        <input class="form-control" type="number" step="0.01" name="MaxPrice" value="@(Model.MaxPrice?.ToString())" placeholder="Max price" />
    </div>
    <div class="col-md-2">
        <input class="form-control" type="date" name="CreatedFrom" value="@createdFromStr" />
    </div>
    <div class="col-md-2">
        <input class="form-control" type="date" name="CreatedTo" value="@createdToStr" />
    </div>

    @* Hidden inputs to keep sorting data between filters *@
    <input type="hidden" name="SortBy" value="@Model.SortBy" />
    <input type="hidden" name="SortDir" value="@Model.SortDir" />

    <div class="col-md-2">
        <button class="btn btn-primary w-100">Filter</button>
    </div>

    @* Small sorting section for price *@
    <div class="col-md-4 ms-auto">
        <div class="card">
            <div class="card-body py-2 d-flex align-items-center justify-content-between">
                <div class="me-3 small text-muted">Sort by Price:</div>
                <div class="btn-group">
                    <a class="btn btn-sm btn-outline-primary" href="@LinkWith("price","asc", 1)">Asc</a>
                    <a class="btn btn-sm btn-outline-primary" href="@LinkWith("price","desc", 1)">Desc</a>
                </div>
            </div>
        </div>
    </div>
</form>

@* Message shown when no products match the filters *@
@if (Model.Product.Count == 0)
{
    <div class="alert alert-info">No products found.</div>
}
else
{
    @* Main product table with sorting on all columns *@
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th class="text-nowrap">
                        <a class="text-decoration-none" href="@LinkWith("id", Model.NextDir("id"), 1)">
                            #
                            <span class="text-muted">@Model.ArrowFor("id")</span>
                        </a>
                    </th>
                    <th>
                        <a class="text-decoration-none" href="@LinkWith("name", Model.NextDir("name"), 1)">
                            Name
                            <span class="text-muted">@Model.ArrowFor("name")</span>
                        </a>
                    </th>
                    <th>
                        <a class="text-decoration-none" href="@LinkWith("owner", Model.NextDir("owner"), 1)">
                            Owner
                            <span class="text-muted">@Model.ArrowFor("owner")</span>
                        </a>
                    </th>
                    <th>
                        <a class="text-decoration-none" href="@LinkWith("category", Model.NextDir("category"), 1)">
                            Category
                            <span class="text-muted">@Model.ArrowFor("category")</span>
                        </a>
                    </th>
                    <th>
                        <a class="text-decoration-none" href="@LinkWith("model", Model.NextDir("model"), 1)">
                            Model
                            <span class="text-muted">@Model.ArrowFor("model")</span>
                        </a>
                    </th>
                    <th class="text-nowrap">
                        <a class="text-decoration-none" href="@LinkWith("price", Model.NextDir("price"), 1)">
                            Price
                            <span class="text-muted">@Model.ArrowFor("price")</span>
                        </a>
                    </th>
                    <th class="text-nowrap">
                        <a class="text-decoration-none" href="@LinkWith("created", Model.NextDir("created"), 1)">
                            Created
                            <span class="text-muted">@Model.ArrowFor("created")</span>
                        </a>
                    </th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Product)
                {
                    <tr>
                        <td>@p.Id</td>
                        <td>@p.Name</td>
                        <td>@p.Owner</td>
                        <td>@(p.Category ?? "-")</td>
                        <td>@(p.Model ?? "-")</td>
                        <td>@p.Price.ToString("0.00")</td>
                        <td class="text-nowrap">@p.CreatedOn.ToString("u")</td>
                        <td class="text-end text-nowrap">
                            @* Action buttons for each product *@
                            <a class="btn btn-sm btn-outline-secondary" asp-page="/Details" asp-route-id="@p.Id">Details</a>
                            <a class="btn btn-sm btn-outline-primary" asp-page="/Edit" asp-route-id="@p.Id">Edit</a>
                            <a class="btn btn-sm btn-outline-danger" asp-page="/Delete" asp-route-id="@p.Id">Delete</a>
                            <a class="btn btn-sm btn-outline-dark" href="/api/products/@p.Id/history/export.csv">History CSV</a>
                            <a class="btn btn-sm btn-outline-dark" href="/api/products/@p.Id/history/export.pdf">History PDF</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@* Pagination section at the bottom of the page *@
@if (Model.TotalPages > 1)
{
    <nav aria-label="Products pagination">
        <ul class="pagination">
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" href="@KeepFiltersLink(i)">@i</a>
                </li>
            }
        </ul>
    </nav>
}
