@{
    ViewData["Title"] = "Home";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Welcome to AgriEnergyConnect</h1>
        <p class="lead">Manage your farmers and products with ease.</p>
    </div>
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center">
                    <i class="bi bi-people-fill" style="font-size: 2.5rem; color: #198754;"></i>
                    <h5 class="card-title mt-3">Farmers</h5>
                    <p class="card-text">View, add, and manage all farmers in your system.</p>
                    <a href="@Url.Action("Index", "Farmer")" class="btn btn-success">Go to Farmers</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center">
                    <i class="bi bi-box-seam" style="font-size: 2.5rem; color: #0d6efd;"></i>
                    <h5 class="card-title mt-3">Products</h5>
                    <p class="card-text">View, add, and manage all products from your farmers.</p>
                    <a href="@Url.Action("Index", "Product")" class="btn btn-primary">Go to Products</a>
                </div>
            </div>
        </div>
    </div>
</div>
