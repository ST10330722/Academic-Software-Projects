@model AgriEnergyConnect.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<h2>Delete Product</h2>
<h4>Are you sure you want to delete this?</h4>
<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">@Model.Category</dd>
        <dt class="col-sm-2">Production Date</dt>
        <dd class="col-sm-10">@Model.ProductionDate.ToShortDateString()</dd>
        <dt class="col-sm-2">Farmer</dt>
        <dd class="col-sm-10">@Model.Farmer?.Name</dd>
    </dl>
</div>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
