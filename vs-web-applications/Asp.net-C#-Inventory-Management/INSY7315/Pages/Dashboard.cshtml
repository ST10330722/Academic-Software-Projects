@page
@model INSY7315.Pages.DashboardModel
@{
    // Sets the title for the browser tab
    ViewData["Title"] = "Dashboard";
}

<h2>Dashboard</h2>

@* Top summary cards showing overall statistics *@
<div class="row g-3 mb-4">
    @* Total number of products in the system *@
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="h6 text-muted">Total Products</div>
                <div class="h3">@Model.TotalProducts</div>
            </div>
        </div>
    </div>

    @* Displays the total value of all products combined *@
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="h6 text-muted">Inventory Value</div>
                <div class="h3">@Model.TotalValue.ToString("0.00")</div>
            </div>
        </div>
    </div>

    @* Provides quick export options for data *@
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="h6 text-muted">Exports</div>
                <a class="btn btn-sm btn-outline-primary me-2" href="/api/products/export.csv">Products CSV</a>
                <a class="btn btn-sm btn-outline-primary" href="/api/products/export.pdf">Products PDF</a>
            </div>
        </div>
    </div>
</div>

@* Section showing top categories and recent alerts *@
<div class="row g-3">
    @* Table listing top categories with product counts and values *@
    <div class="col-md-7">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Top Categories</h5>
                <table class="table table-sm">
                    <thead>
                        <tr><th>Category</th><th>Count</th><th>Value</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.TopCategories)
                        {
                            <tr>
                                <td>@c.Category</td>
                                <td>@c.Count</td>
                                <td>@c.Value.ToString("0.00")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* List of the most recent alerts *@
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Recent Alerts</h5>
                @if (Model.RecentAlerts.Count == 0)
                {
                    <div class="text-muted">No alerts yet.</div>
                }
                else
                {
                    <ul class="list-group">
                        @foreach (var a in Model.RecentAlerts)
                        {
                            <li class="list-group-item">
                                <div class="small text-muted">@a.CreatedAt</div>
                                <div>@a.Message</div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
