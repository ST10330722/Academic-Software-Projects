@page "{id:int}"
@model INSY7315.Pages.DetailsModel
@{
    // Sets the title for the browser tab
    ViewData["Title"] = "Details";
}

<h2>Product Details</h2>

@* Displays detailed information about a selected product *@
<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Product.Id</dd>

    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Product.Name</dd>

    <dt class="col-sm-2">Owner</dt>
    <dd class="col-sm-10">@Model.Product.Owner</dd>

    <dt class="col-sm-2">Category</dt>
    <dd class="col-sm-10">@Model.Product.Category</dd>

    <dt class="col-sm-2">Model</dt>
    <dd class="col-sm-10">@Model.Product.Model</dd>

    <dt class="col-sm-2">Price</dt>
    <dd class="col-sm-10">@Model.Product.Price</dd>

    <dt class="col-sm-2">Created</dt>
    <dd class="col-sm-10">@Model.Product.CreatedOn</dd>
</dl>

@* Buttons to view the price history or go back to the product list *@
<p>
    <a class="btn btn-outline-primary" asp-page="/History" asp-route-id="@Model.Product.Id">Price History</a>
    <a class="btn btn-secondary" asp-page="/Index">Back</a>
</p>
