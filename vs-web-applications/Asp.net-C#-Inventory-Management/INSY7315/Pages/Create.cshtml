@page
@model INSY7315.Pages.CreateModel
@{
    // Sets the page title for the browser
    ViewData["Title"] = "Create";
}

<h2>Create Product</h2>

@* Form used to create a new product entry *@
<form method="post" class="row g-3">
    @* Product name field (required) *@
    <div class="col-md-6">
        <label class="form-label">Name</label>
        <input asp-for="Product.Name" class="form-control" />
        <span asp-validation-for="Product.Name" class="text-danger"></span>
    </div>

    @* Owner field (required) *@
    <div class="col-md-6">
        <label class="form-label">Owner</label>
        <input asp-for="Product.Owner" class="form-control" />
        <span asp-validation-for="Product.Owner" class="text-danger"></span>
    </div>

    @* Optional category input *@
    <div class="col-md-4">
        <label class="form-label">Category</label>
        <input asp-for="Product.Category" class="form-control" />
    </div>

    @* Optional model input *@
    <div class="col-md-4">
        <label class="form-label">Model</label>
        <input asp-for="Product.Model" class="form-control" />
    </div>

    @* Product price field with validation *@
    <div class="col-md-4">
        <label class="form-label">Price</label>
        <input asp-for="Product.Price" class="form-control" />
        <span asp-validation-for="Product.Price" class="text-danger"></span>
    </div>

    @* Submit and cancel buttons *@
    <div class="col-12">
        <button class="btn btn-primary">Save</button>
        <a class="btn btn-secondary" asp-page="/Index">Cancel</a>
    </div>
</form>

@* Enables client-side validation scripts *@
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
