@{
    // Sets the site name used in the title and navbar
    var site = "Inventory";
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@site</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Loads Bootstrap for styling and layout -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
</head>
<body>
    <!-- Main navigation bar displayed on all pages -->
    <nav class="navbar navbar-expand navbar-dark bg-dark mb-3">
        <div class="container-fluid">
            <!-- Site name links back to the home page -->
            <a class="navbar-brand" asp-page="/Index">@site</a>

            <!-- Left side navigation links for main pages -->
            <div class="navbar-nav me-auto">
                <a class="nav-link" asp-page="/Index">Products</a>
                <a class="nav-link" asp-page="/Create">Create</a>
                <a class="nav-link" asp-page="/Dashboard">Dashboard</a>
                <a class="nav-link" asp-page="/Alerts">Alerts</a>
                <a class="nav-link" asp-page="/Export">Exports</a>
            </div>

            <!-- Right side navigation for login and user info -->
            <div class="navbar-nav ms-auto">
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <!-- Main content area where each page’s content is displayed -->
    <main class="container pb-5">
        @RenderBody()
    </main>

    <!-- Optional section for page-specific scripts -->
    @RenderSection("Scripts", required: false)
</body>
</html>
