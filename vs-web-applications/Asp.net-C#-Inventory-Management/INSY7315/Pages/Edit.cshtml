@page "{id:int}"
@model INSY7315.Pages.EditModel
@{
    // Sets the page title in the browser tab
    ViewData["Title"] = "Edit";
}

<h2>Edit Product</h2>

@* Form for editing an existing product *@
<form method="post" class="row g-3">
    @* Hidden input to keep track of the product ID *@
    <input type="hidden" asp-for="Product.Id" />

    @* Product name field (required) *@
    <div class="col-md-6">
        <label class="form-label">Name</label>
        <input asp-for="Product.Name" class="form-control" />
        <span asp-validation-for="Product.Name" class="text-danger"></span>
    </div>

    @* Product owner field (required) *@
    <div class="col-md-6">
        <label class="form-label">Owner</label>
        <input asp-for="Product.Owner" class="form-control" />
        <span asp-validation-for="Product.Owner" class="text-danger"></span>
    </div>

    @* Optional category field *@
    <div class="col-md-4">
        <label class="form-label">Category</label>
        <input asp-for="Product.Category" class="form-control" />
    </div>

    @* Optional model field *@
    <div class="col-md-4">
        <label class="form-label">Model</label>
        <input asp-for="Product.Model" class="form-control" />
    </div>

    @* Price field with validation *@
    <div class="col-md-4">
        <label class="form-label">Price</label>
        <input asp-for="Product.Price" class="form-control" />
        <span asp-validation-for="Product.Price" class="text-danger"></span>
    </div>

    @* Buttons to save or cancel the edit *@
    <div class="col-12">
        <button class="btn btn-primary">Save</button>
        <a class="btn btn-secondary" asp-page="/Index">Cancel</a>
    </div>
</form>

@* Includes validation scripts for client-side checks *@
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
